{
  "name": "cfire-chat-keeper",
  "displayName": "CFire Chat Keeper",
  "version": "0.2.2",
  "description": "批量提取 DeepSeek / ChatGPT / 豆包 等 Web 端对话并保存至本地，陪你守护每一次 AI 对话",
  "author": "you",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package"
  },
  "dependencies": {
    "plasmo": "0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "typescript": "5.3.3"
  },
  "manifest": {
    "host_permissions": [
      "https://chat.deepseek.com/*",
      "https://chatgpt.com/*",
      "https://chat.openai.com/*",
      "https://www.doubao.com/*"
    ],
    "permissions": [
      "storage",
      "scripting",
      "activeTab",
      "downloads"
    ],
    "content_security_policy": {
      "extension_pages": "script-src 'self'; object-src 'self'; img-src 'self' data: https:"
    }
  }
}
